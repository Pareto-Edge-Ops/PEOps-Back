# Astra BACKEND deployment configuration. Copy to `.env` and edit before deploying.
#   cp .env.example .env
#
# This is the DEPLOYMENT-scoped env for the backend stack (docker compose: the
# API port, database/object-store credentials, JWT/OAuth secrets, the public
# product origin). It is distinct from the app-level dev config used by
# `app/config.py` when running uvicorn directly.

# --- where the API is published ----------------------------------------------
# Host interface and port the API listens on. ASTRA_API_BIND defaults to
# 127.0.0.1 (localhost only). Set it to 0.0.0.0 when the frontend stack runs on
# another host/VM and must reach this API across the private network — keep the
# VM's :8000 on a private bridge/LAN, NOT exposed to the public internet
# (public traffic enters via the frontend's Cloudflare Tunnel only).
ASTRA_API_BIND=127.0.0.1
ASTRA_API_PORT=8000

# The public origin browsers use to reach the PRODUCT — i.e. the frontend's
# Caddy (fronted by Cloudflare), NOT this API. Drives CORS and the base URLs
# rendered in SDK snippets.  Production: https://astra.kwon5700.kr
ASTRA_PUBLIC_ORIGIN=http://localhost:8080

# --- secrets (CHANGE THESE) ---------------------------------------------------
# Strong random string — signs session JWTs. Generate: openssl rand -hex 32
ASTRA_JWT_SECRET=change-me-please-openssl-rand-hex-32

POSTGRES_USER=astra
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=astra

MINIO_ROOT_USER=astraadmin
MINIO_ROOT_PASSWORD=change-me-minio-secret
ASTRA_S3_BUCKET=astra-artifacts

# --- owner-only analytics (self-hosted Umami) --------------------------------
# Signs the Umami auth tokens. Generate: openssl rand -hex 32. The Umami admin
# starts as admin/umami — CHANGE the password on first sign-in; that login is
# the owner-only boundary. Umami reuses this Postgres (a dedicated `umami` DB).
UMAMI_APP_SECRET=change-me-umami-openssl-rand-hex-32
# Host interface Umami publishes on (port 3001). Like ASTRA_API_BIND: keep
# 127.0.0.1 for single-box, or set 0.0.0.0 so the frontend's Caddy / Cloudflare
# Tunnel on another host can reach it at <this-VM>:3001.
UMAMI_BIND=0.0.0.0

# --- Google OAuth (optional) --------------------------------------------------
# From Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# Register the callback URL below under the client's "Authorized redirect URIs".
# Leave blank to disable Google sign-in (email/password still works).
# Production callback: https://astra.kwon5700.kr/api/auth/google/callback
ASTRA_GOOGLE_CLIENT_ID=
ASTRA_GOOGLE_CLIENT_SECRET=
# Leave UNSET to derive the callback from ASTRA_PUBLIC_ORIGIN
# (<origin>/api/auth/google/callback) — the safest default, so it never drifts
# to a dev host in production. Set explicitly only to override. The startup
# guard warns if an explicit value's host differs from ASTRA_PUBLIC_ORIGIN.
# ASTRA_GOOGLE_REDIRECT_URI=

# --- behavior -----------------------------------------------------------------
# Set to 1 ONLY when serving over HTTPS (Secure cookies require https). Behind a
# Cloudflare Tunnel the browser↔edge leg is HTTPS, so set 1 in production.
ASTRA_COOKIE_SECURE=0
# Session cookie SameSite. `lax` is correct for the single-origin product.
ASTRA_COOKIE_SAMESITE=lax
# 1 = synthetic dashboard traffic for demoing the Telemetry tab. 0 in production.
ASTRA_TELEMETRY_SIM_ENABLED=0
# 1 = tiny model + few trials (fast demo). 0 = real compression pipeline.
ASTRA_FAST_PIPELINE=0
# Adaptive Optuna trial budget for the Pareto 3D search (real mode). The trial
# count is DYNAMIC, not a static number: per-model trials = clamp(10·D + 10, 30,
# ASTRA_PARETO_TRIALS), where D is the live search dimensionality. So
# ASTRA_PARETO_TRIALS is the CEILING (validated default 150), and small models
# run far fewer trials. Set ASTRA_PARETO_ADAPTIVE=0 to use it as a fixed count.
ASTRA_PARETO_ADAPTIVE=1
ASTRA_PARETO_TRIALS=150

# --- feedback widget → GitHub Issues -----------------------------------------
# When BOTH are set, feedback submitted in the app (sidebar → dialog) also opens
# a GitHub issue in the target repo. Recommended: a PRIVATE repo + a fine-grained
# PAT scoped to Issues: Read and write on that one repo. Leave blank to store
# feedback in the DB only.
ASTRA_FEEDBACK_GITHUB_TOKEN=
ASTRA_FEEDBACK_GITHUB_REPO=          # owner/repo, e.g. Pareto-Edge-Ops/Astra-Issue
