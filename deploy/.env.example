# PEOps deployment configuration. Copy to `.env` and edit before deploying.
#   cp .env.example .env
#
# This is the DEPLOYMENT-scoped env (docker compose: ports, the public origin,
# database/object-store credentials, OAuth). It is distinct from the app-level
# dev config used by `app/config.py` when running uvicorn directly.

# Public port the product is served on (Caddy → SPA + /api).
PEOPS_PORT=8080
# The public origin browsers use. Must match how users reach the app. The API
# reads this (PEOPS_PUBLIC_ORIGIN) to render correct base URLs in SDK snippets
# and to set CORS.
PEOPS_PUBLIC_ORIGIN=http://localhost:8080

# --- secrets (CHANGE THESE) ---------------------------------------------------
# Strong random string — signs session JWTs. Generate: openssl rand -hex 32
PEOPS_JWT_SECRET=change-me-please-openssl-rand-hex-32

POSTGRES_USER=peops
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=peops

MINIO_ROOT_USER=peopsadmin
MINIO_ROOT_PASSWORD=change-me-minio-secret
PEOPS_S3_BUCKET=peops-artifacts

# --- Google OAuth (optional) --------------------------------------------------
# From Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# Register the callback URL below under the client's "Authorized redirect URIs".
# Leave blank to disable Google sign-in (email/password still works).
PEOPS_GOOGLE_CLIENT_ID=
PEOPS_GOOGLE_CLIENT_SECRET=
PEOPS_GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# --- behavior -----------------------------------------------------------------
# Set to 1 ONLY when serving over HTTPS (Secure cookies require https).
PEOPS_COOKIE_SECURE=0
# 1 = tiny model + few trials (fast demo). 0 = real compression pipeline.
PEOPS_FAST_PIPELINE=0
