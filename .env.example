# Astra backend configuration (all optional — sensible defaults built in)

# persistence
ASTRA_DB_PATH=astra.db
ASTRA_STORAGE_DIR=storage

# server
ASTRA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# cookies — set 0 for plain-HTTP local dev (Secure cookies require https)
ASTRA_COOKIE_SECURE=0

# Google OAuth (optional) — the login/signup pages show the "Continue with
# Google" button only when BOTH of these are set (GET /api/auth/providers then
# reports google:true). Leave blank to disable; email/password still works.
# Create a Web OAuth client at Google Cloud Console → APIs & Services →
# Credentials, and register the redirect URI below under "Authorized redirect URIs".
ASTRA_GOOGLE_CLIENT_ID=
ASTRA_GOOGLE_CLIENT_SECRET=
# Must match your browser origin: 5173 = vite dev, 8080 = Caddy stack, or prod domain.
ASTRA_GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback

# determinism — pin for byte-identical responses across restarts
ASTRA_SEED=42
# ASTRA_REF_DATE=2026-06-06T00:00:00Z

# real compression pipeline (astra engine)
ASTRA_FAST_PIPELINE=0          # 1 = tiny model + 4 trials (tests/CI/demos)
ASTRA_PARETO_TRIALS=14         # Optuna trials per import
ASTRA_N_PROBES=16              # synthetic calibration probes
ASTRA_MAX_COMPRESSIBLE_OPS=24  # UOSA cap (one ORT session per op)
ASTRA_JOB_TIMEOUT_SEC=900
ASTRA_JOB_WORKERS=2

# telemetry closed-loop
ASTRA_DRIFT_MODELS=m_ptkorea_qwen
ASTRA_DRIFT_ACC_THRESHOLD=0.5
ASTRA_DRIFT_P95_THRESHOLD_PCT=10.0

# feedback widget (sidebar → in-app dialog → POST /api/feedback). Every
# submission is stored in the DB. When BOTH of these are set, it ALSO opens a
# GitHub issue in the target repo. Recommended: a PRIVATE repo (feedback can be
# sensitive) + a fine-grained PAT scoped to Issues: Read and write on that one
# repo. Leave blank to store feedback in the DB only.
ASTRA_FEEDBACK_GITHUB_TOKEN=
ASTRA_FEEDBACK_GITHUB_REPO=          # owner/repo, e.g. AstraFoundation/Astra-Issue
